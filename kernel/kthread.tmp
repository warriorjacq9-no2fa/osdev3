#include <kernel/kthread.h>
#include <kernel/kmalloc.h>
#include <kernel/klog.h>
#include <kernel/ringbuffer.h>
#include <arch.h>
#include <ctx.h>
#include <stdbool.h>
#include <string.h>

kt_context_t* ctx_buf[64];
size_t c_thread;
size_t max_t;
bool has_thread = false;

int kthread_init() {
    lock();
    memset(ctx_buf, 0, sizeof(ctx_buf));
    max_t = 1;
    c_thread = 0;
    // Establish the kernel as thread 0
    kt_context_t *kctx = kmalloc(sizeof(kt_context_t), 0);
    kctx->thread = NULL;
    kctx->state = TS_RUNNING;
    kctx->stack_base = (void*)KSTACK_BASE;
    kctx->sp = 0;
    ctx_buf[0] = kctx;
    unlock();
    return 0;
}

int kthread_create(size_t *fd, kthread_t thread, void* arg, char priv) {
    lock();
    size_t t;
    kt_context_t *ctx = NULL;
    for(t = 0; t < max_t; t++) {
        if(ctx_buf[t]->state == TS_UNUSED) {
            ctx = ctx_buf[t];
            break;
        }
    }
    char flags = 0;
    if(priv != PRIV_KERNEL) flags = MEM_USER;
    if(t >= max_t) {
        ctx = kmalloc(sizeof(kt_context_t), flags);
        ctx_buf[t] = ctx;
    }
    void* base = kmalloc(THREAD_STACK_SIZE, flags);
    void* kbase = kmalloc(THREAD_STACK_SIZE, 0);
    if(!base || !kbase) {
        kprintf(LOG_WARN, "kthread", "kmalloc returned NULL\r\n");
        return 1;
    }
    ctx->thread = thread;
    ctx->state = TS_RUNNING;
    ctx->arg = arg;

    ctx->stack_base = base;
    ctx->kstack_base = kbase;
    ctx->sp = (uintptr_t)base + THREAD_STACK_SIZE;
    ctx->ksp = (uintptr_t)kbase + THREAD_STACK_SIZE;
    kt_init_context(ctx, priv);
    kprintf(LOG_INFO, "kthread", "Added thread at index %u, with sp 0x%08X (ksp 0x%08X), function at %p\r\n",
        t, ctx->sp, ctx->ksp, thread
    );
    *fd = t;
    has_thread = true;
    unlock();
    return 0;
}

void kthread_schedule(uintptr_t **curr_sp, uintptr_t **next_sp) {
    *curr_sp = NULL;
    *next_sp = NULL;

    if (max_t == 0) return;

    // Free done threads
    for (size_t i = 0; i < max_t; i++) {
        kt_context_t *ctx = ctx_buf[i];
        if (!ctx || ctx->state != TS_DONE) continue;

        kfree(ctx->stack_base);
        kfree(ctx->kstack_base);
        kfree(ctx);
        ctx_buf[i] = NULL;
    }

    // Find the next running thread
    size_t tn = (c_thread + 1) % max_t;
    size_t i = 0;

    while (i < max_t) {
        kt_context_t *ctx = ctx_buf[tn];

        if (ctx && ctx->state == TS_RUNNING && tn != c_thread)
            break;                              /* found a candidate */

        tn = (tn + 1) % max_t;
        i++;
    }

    if (i == max_t) return; // No runnable thread

    if (!ctx_buf[c_thread]) return;

    kstack_update(ctx_buf[tn]->ksp);
    kprintf(LOG_INFO, "kthread", "%u -> %u\r\n", c_thread, tn);

    *curr_sp = &ctx_buf[c_thread]->sp;
    *next_sp = &ctx_buf[tn]->sp;
    c_thread = tn;
}

void kthread(kt_context_t *ctx) {
    ctx->res = ctx->thread(ctx->arg);
    while(1) wait();
}

// This function is returned to by an exiting thread
void kthread_ret() {
    kt_context_t *ctx = ctx_buf[c_thread];
    ctx->state = TS_DONE;
    //kprintf(LOG_INFO, "kthread", "Thread %u exited\r\n", c_thread);
}